    errorFrame.Position = UDim2.new(0.5, -125, 0, -50)
    errorFrame.BackgroundColor3 = Color3.fromRGB(50, 20, 30)
    errorFrame.BackgroundTransparency = 0.1
    errorFrame.Parent = mainFrame
    
    local errCorner = Instance.new("UICorner")
    errCorner.CornerRadius = UDim.new(0, 10)
    errCorner.Parent = errorFrame
    
    local errStroke = Instance.new("UIStroke")
    errStroke.Color = Color3.fromRGB(255, 60, 100)
    errStroke.Thickness = 1
    errStroke.Parent = errorFrame
    
    local errText = Instance.new("TextLabel")
    errText.Text = "❌ " .. message
    errText.Size = UDim2.new(1, 0, 1, 0)
    errText.BackgroundTransparency = 1
    errText.TextColor3 = Color3.fromRGB(255, 180, 200)
    errText.TextSize = 14
    errText.Font = Enum.Font.Gotham
    errText.Parent = errorFrame
    
    local tweenIn = TweenService:Create(errorFrame, TweenInfo.new(0.3, Enum.EasingStyle.Back), {Position = UDim2.new(0.5, -125, 0, 10)})
    tweenIn:Play()
    
    task.wait(2.5)
    local tweenOut = TweenService:Create(errorFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {Position = UDim2.new(0.5, -125, 0, -50)})
    tweenOut:Play()
    tweenOut.Completed:Connect(function() errorFrame:Destroy() end)
end

